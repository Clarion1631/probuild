generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  role             String           @default("FIELD_CREW") // ADMIN, MANAGER, FIELD_CREW, FINANCE
  status           String           @default("PENDING") // PENDING, ACTIVATED, DISABLED
  hourlyRate       Decimal            @default(0)
  burdenRate       Decimal            @default(0)
  pinCode          String? // Used for mobile app quick login
  invitedAt        DateTime?        @default(now())
  timeEntries      TimeEntry[]
  assignedProjects Project[]        @relation("CrewAssignments")
  taskAssignments  TaskAssignment[]
  taskComments     TaskComment[]
  uploadedFiles    ProjectFile[]
  permissions      UserPermission?
  projectAccess    ProjectAccess[]
  leadTasks        LeadTask[]
  managedLeads     Lead[]           @relation("LeadManager")
  managedProjects  Project[]        @relation("ProjectManager")
  dailyLogs        DailyLog[]
  documentComments DocumentComment[]
  teamMessages     TeamMessage[]
}

model Client {
  id              String  @id @default(cuid())
  name            String
  initials        String
  email           String?
  companyName     String?
  primaryPhone    String?
  additionalEmail String?
  additionalPhone String?

  // Normalized E.164 (e.g. "+13609542757") for indexed phone lookups (Twilio inbound).
  // Populated by createClient/updateClient via normalizeE164().
  primaryPhoneE164    String?
  additionalPhoneE164 String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  country      String?

  internalNotes String?

  projects Project[]
  leads    Lead[]
  invoices Invoice[]
  retainers Retainer[]

  @@index([primaryPhoneE164])
  @@index([additionalPhoneE164])
}

model Lead {
  id                String    @id @default(cuid())
  number            Int       @default(autoincrement())
  name              String
  clientId          String
  client            Client    @relation(fields: [clientId], references: [id])
  stage             String    @default("New") // New, Followed Up, Connected, Estimate Sent, Won, Closed
  source            String? // My website, Houzz, Manually created lead
  projectType       String?
  location          String?
  targetRevenue     Decimal?
  expectedStartDate DateTime?
  createdAt         DateTime  @default(now())

  // Houzz Pro Enhancements
  tags           String? // Comma separated tags
  expectedProfit Decimal?
  lastActivityAt DateTime @default(now())

  managerId String?
  manager   User?   @relation("LeadManager", fields: [managerId], references: [id])

  isUnread     Boolean   @default(true)
  snoozedUntil DateTime?
  isArchived   Boolean   @default(false)

  // Relations
  estimates      Estimate[]
  roomDesigns    RoomDesign[]
  contracts      Contract[]
  files          ProjectFile[]
  folders        FileFolder[]
  tasks          LeadTask[]
  notes          LeadNote[]
  meetings       LeadMeeting[]
  takeoffs       Takeoff[]
  clientMessages ClientMessage[]
  scheduleTasks  ScheduleTask[]
  message        String? // Initial inquiry message from the client
  project        Project? // reverse relation: the project created from this lead

  @@index([createdAt])
  @@index([clientId])
  @@index([stage])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadTask {
  id         String    @id @default(cuid())
  leadId     String
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title      String
  status     String    @default("To Do") // To Do, In Progress, Done
  dueDate    DateTime?
  tags       String? // Comma-separated tag strings
  assigneeId String?
  assignee   User?     @relation(fields: [assigneeId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model LeadMeeting {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title       String
  meetingType String   @default("Video Call") // Phone Call, Onsite Visit, Video Call
  duration    Int      @default(60) // minutes
  scheduledAt DateTime
  endAt       DateTime
  location    String? // for Onsite Visit
  videoApp    String? // e.g. "Google Meet"
  description String?
  status      String   @default("Scheduled") // Scheduled, Completed, Cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id                  String                       @id @default(cuid())
  number              Int                          @default(autoincrement())
  name                String
  clientId            String
  client              Client                       @relation(fields: [clientId], references: [id])
  leadId              String?                      @unique
  lead                Lead?                        @relation(fields: [leadId], references: [id], onDelete: Restrict)
  viewedAt            DateTime                     @default(now())
  createdAt           DateTime                     @default(now())
  location            String?
  // Geofencing for mobile time-clock (added for gtr-probuild-mobile integration)
  locationLat            Float?
  locationLng            Float?
  geofenceRadiusMeters   Int?     @default(100)
  status              String                       @default("In Progress") // In Progress, Closed, Paid Ready to Start
  type                String? // Kitchen Remodeling, Patio, Water Damage
  code                String?
  tags                String?
  color               String?                      @default("#3b82f6") // Added color field
  managerId           String?
  manager             User?                        @relation("ProjectManager", fields: [managerId], references: [id])
  estimates           Estimate[]
  invoices            Invoice[]
  budgets             Budget[]
  timeEntries         TimeEntry[]
  roomDesigns         RoomDesign[]
  contracts           Contract[]
  crew                User[]                       @relation("CrewAssignments")
  scheduleTasks       ScheduleTask[]
  files               ProjectFile[]
  folders             FileFolder[]
  userAccess          ProjectAccess[]
  subcontractorAccess SubcontractorProjectAccess[]
  takeoffs            Takeoff[]
  portalVisibility    PortalVisibility?
  messageThreads      MessageThread[]
  clientMessages      ClientMessage[]
  changeOrders        ChangeOrder[]
  purchaseOrders      PurchaseOrder[]
  selectionBoards     SelectionBoard[]
  dailyLogs           DailyLog[]
  moodBoards          MoodBoard[]
  retainers           Retainer[]
  bidPackages         BidPackage[]
  teamMessages        TeamMessage[]
  activityLogs        ActivityLog[]

  @@index([viewedAt])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model RoomDesign {
  id           String      @id @default(cuid())
  name         String
  roomType     String // kitchen | bathroom | laundry | bedroom | other
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leadId       String?
  lead         Lead?       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  layoutJson   Json // walls, dimensions, camera, surfaces
  shareToken   String?     @unique
  shareEnabled Boolean     @default(false)
  thumbnail    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  assets       RoomAsset[]

  // XOR check: exactly one of projectId or leadId must be non-null.
  // Enforced at the DB via CHECK constraint "RoomDesign_owner_xor" (not expressible in Prisma).
  @@index([projectId, updatedAt])
  @@index([leadId, updatedAt])
}

model RoomAsset {
  id           String     @id @default(cuid())
  roomDesignId String
  roomDesign   RoomDesign @relation(fields: [roomDesignId], references: [id], onDelete: Cascade)
  assetType    String // cabinet | appliance | fixture | window | door
  assetId      String // references asset-registry.ts id
  positionX    Float
  positionY    Float
  positionZ    Float
  rotationY    Float      @default(0)
  scaleX       Float      @default(1)
  scaleY       Float      @default(1)
  scaleZ       Float      @default(1)
  metadata     Json?
  createdAt    DateTime   @default(now())

  @@index([roomDesignId])
}

model Estimate {
  id     String @id @default(cuid())
  number Int    @default(autoincrement())
  title  String

  // Flexible Relation: Can belong to a Project OR a Lead
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])

  code             String
  status           String                    @default("Sent") // Invoiced, Partially Paid, Sent, Approved
  privacy          String                    @default("Shared") // Shared, Private
  createdAt        DateTime                  @default(now())
  totalAmount      Decimal
  balanceDue       Decimal
  items            EstimateItem[]
  expenses         Expense[]
  paymentSchedules EstimatePaymentSchedule[]
  budget           Budget?
  takeoff          Takeoff?

  // Processing fee & expiration
  processingFeeMarkup Decimal?
  hideProcessingFee   Boolean   @default(true)
  expirationDate      DateTime?
  archivedAt          DateTime?
  taxExempt           Boolean   @default(false)

  // AI budget fill: target overall margin for the estimate (gross margin %, not markup)
  targetMarginPercent Float     @default(25)

  // Phase 7: Contracts & Approvals
  approvedBy        String?
  approvedAt        DateTime?
  approvalIp        String?
  approvalUserAgent String?
  signatureUrl      String?
  contractId        String?
  contract          Contract? @relation(fields: [contractId], references: [id])

  // Memo / notes
  memo String?

  // Phase 8: Tracking
  viewedAt DateTime?

  // Phase 9: Terms & Sending
  termsAndConditions String? // Snapshot of T&C HTML at time of sending
  sentAt             DateTime? // When the estimate was emailed to the client
  changeOrders       ChangeOrder[]
  files              EstimateFile[]

  @@index([createdAt])
  @@index([projectId])
  @@index([leadId])
  @@index([status])
}

model EstimateFile {
  id         String   @id @default(cuid())
  name       String
  url        String
  size       Int
  type       String // Mime type
  estimateId String
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model EstimatePaymentSchedule {
  id                    String    @id @default(cuid())
  estimateId            String
  estimate              Estimate  @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name                  String
  percentage            Float? // Optional: represent this payment as a % of the total
  amount                Decimal
  dueDate               DateTime?
  order                 Int       @default(0)
  createdAt             DateTime  @default(now())
  status                String    @default("Pending")
  stripeSessionId       String?
  stripePaymentIntentId String?
  paymentMethod         String? // Stripe: "card"/"ach"; manual: "check"/"cash"
  referenceNumber       String? // check # / confirmation #
  notes                 String? // free-form memo
  receiptSentAt         DateTime? // last time admin sent the receipt email
  paidAt                DateTime?
  paymentDate           DateTime?

  @@index([estimateId])
}

model EstimateItem {
  id            String         @id @default(cuid())
  estimateId    String
  estimate      Estimate       @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  type          String         @default("Material") // Legacy fallback
  quantity      Float          @default(1)
  baseCost      Decimal? // Raw cost before markup (internal only)
  markupPercent Float          @default(25) // Markup percentage (internal only)
  unitCost      Decimal          @default(0) // Sell price = baseCost * (1 + markupPercent/100)
  total         Decimal          @default(0)
  order         Int            @default(0)
  parentId      String?
  parent        EstimateItem?  @relation("SubItems", fields: [parentId], references: [id], onDelete: Cascade)
  subItems      EstimateItem[] @relation("SubItems")
  expenses      Expense[]
  costCodeId    String?
  costCode      CostCode?      @relation(fields: [costCodeId], references: [id])
  costTypeId    String?
  costType      CostType?      @relation(fields: [costTypeId], references: [id])
  approvalStatus String?        // pending, approved, rejected
  approvalNote   String?
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  budgetQuantity   Float?
  budgetUnit       String?
  budgetRate       Decimal?
  timeEntries    TimeEntry[]
  scheduleTasks  ScheduleTask[]
  createdAt      DateTime       @default(now())

  @@index([estimateId])
  @@index([purchaseOrderId])
}

model Expense {
  id          String        @id @default(cuid())
  estimateId  String
  estimate    Estimate      @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  itemId      String?
  item        EstimateItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  costCodeId  String?
  costCode    CostCode?     @relation(fields: [costCodeId], references: [id])
  costTypeId  String?
  costType    CostType?     @relation(fields: [costTypeId], references: [id])
  amount      Decimal
  vendor      String?
  date        DateTime?
  description String?
  receiptUrl  String?
  status      String        @default("Pending") // Pending, Reviewed

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  createdAt DateTime @default(now())

  @@index([estimateId])
}

model Invoice {
  id          String    @id @default(cuid())
  number      Int       @default(autoincrement())
  code        String
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status      String    @default("Draft") // Draft, Issued, Paid, Overdue
  totalAmount Decimal     @default(0)
  subtotal    Decimal     @default(0)  // pre-tax
  taxRate     Decimal     @default(0)  // percent, e.g. 8.8
  taxAmount   Decimal     @default(0)  // dollars
  balanceDue  Decimal     @default(0)
  notes       String?
  issueDate   DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  createdAt   DateTime  @default(now())

  payments PaymentSchedule[]

  @@index([projectId])
  @@index([createdAt])
}

model PaymentSchedule {
  id                    String    @id @default(cuid())
  invoiceId             String
  invoice               Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name                  String
  amount                Decimal
  status                String    @default("Pending") // Pending, Paid, Canceled
  dueDate               DateTime?
  paymentDate           DateTime?
  stripeSessionId       String?
  stripePaymentIntentId String?
  paymentMethod         String? // Stripe: "card"/"ach"; manual: "check"/"cash"
  referenceNumber       String? // check # / confirmation #
  notes                 String? // free-form memo
  receiptSentAt         DateTime? // last time admin sent the receipt email
  paidAt                DateTime?
  createdAt             DateTime  @default(now())

  @@index([invoiceId])
  @@index([stripePaymentIntentId])
}

model Budget {
  id                  String   @id @default(cuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  estimateId          String   @unique
  estimate            Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  totalLaborBudget    Decimal    @default(0)
  totalMaterialBudget Decimal    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CostCode {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. "01-DEMO", "02-FRAME"
  name        String // e.g. "Demolition", "Framing"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  estimateItems      EstimateItem[]
  timeEntries        TimeEntry[]
  expenses           Expense[]
  changeOrderItems   ChangeOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  catalogItems       CatalogItem[]
}

model CostType {
  id          String   @id @default(cuid())
  name        String   @unique // "Labor", "Material", "Unit", "Allowance", etc.
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  estimateItems      EstimateItem[]
  timeEntries        TimeEntry[]
  expenses           Expense[]
  changeOrderItems   ChangeOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
}

model TimeEntry {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCodeId String?
  costCode   CostCode? @relation(fields: [costCodeId], references: [id])
  costTypeId String?
  costType   CostType? @relation(fields: [costTypeId], references: [id])

  estimateItemId String?
  estimateItem   EstimateItem? @relation(fields: [estimateItemId], references: [id])

  startTime     DateTime
  endTime       DateTime?
  durationHours Float?

  latitude  Float?
  longitude Float?

  laborCost  Decimal?
  burdenCost Decimal?

  scheduleTaskId String?
  scheduleTask   ScheduleTask? @relation(fields: [scheduleTaskId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Audit history
  editedByManagerId String?
  editedAt          DateTime?

  // Mobile edit audit (gtr-probuild-mobile)
  isEdited          Boolean   @default(false)
  originalStartTime DateTime?
  originalEndTime   DateTime?
  editNotes         String?

  // Geofence telemetry (gtr-probuild-mobile)
  offsiteMs         Int       @default(0)
  isOffsite         Boolean   @default(false)
  lastLocationCheck DateTime?

  @@index([projectId])
  @@index([userId])
}

model Contract {
  id        String   @id @default(cuid())
  number    Int      @default(autoincrement())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  title  String
  body   String // HTML string of the legal agreement (with merge fields resolved)
  status String @default("Draft") // Draft, Sent, Viewed, Signed, Declined

  estimates Estimate[]

  // Signing fields (current/latest)
  approvedBy        String?
  approvedAt        DateTime?
  approvalIp        String?
  approvalUserAgent String?
  signatureUrl      String? // PNG data URL of drawn signature

  // Contractor signing fields
  contractorSignedBy       String?
  contractorSignedAt       DateTime?
  contractorSignatureUrl   String? // PNG data URL of contractor's drawn signature

  // Sending
  sentAt   DateTime?
  viewedAt DateTime?

  // Portal access token — stable magic-link for client to view/sign the contract without a login.
  // Generated on first send, preserved on resend so old email links keep working.
  accessToken String? @unique

  // Recurring (e.g. lien release every 30 days)
  recurringDays  Int? // null = one-time, 30 = every 30 days
  nextDueDate    DateTime? // When the next signing is due
  signingRecords ContractSigningRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractSigningRecord {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  signedBy     String // Full legal name
  signedAt     DateTime @default(now())
  signatureUrl String? // PNG data URL of drawn signature
  ipAddress    String?
  userAgent    String?

  periodStart DateTime? // Start of the period this release covers
  periodEnd   DateTime? // End of the period this release covers

  notes String? // Optional notes (e.g. payment amount)

  createdAt DateTime @default(now())
}

model CompanySettings {
  id                  String  @id @default("singleton")
  companyName         String  @default("My Construction Co.")
  address             String?
  phone               String?
  email               String?
  website             String?
  logoUrl             String?
  licenseNumber       String?
  notificationEmail   String? // Where to send View/Sign alerts
  projectStatuses     String? // JSON string array of custom statues [{label, value, color, dot}, ...]
  subcontractorTrades String? // JSON string array of trades ["Architect", "Asphalt", "Bricklaying"]
  stripeEnabled       Boolean @default(false)
  enableCard          Boolean @default(true)
  enableBankTransfer  Boolean @default(false)
  enableAffirm        Boolean @default(false)
  enableKlarna        Boolean @default(false)

  // Processing Fees
  passProcessingFee  Boolean @default(false)
  cardProcessingRate Decimal   @default(2.9)
  cardProcessingFlat Decimal   @default(0.30)

  // Calendar settings
  workDays      String? // JSON array: ["Mon","Tue","Wed","Thu","Fri"]
  workdayStart  String? // e.g. "07:00"
  workdayEnd    String? // e.g. "17:00"

  // Sales taxes
  salesTaxes String? // JSON array: [{name, rate, isDefault}]

  updatedAt DateTime @updatedAt
}

model DocumentTemplate {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("terms") // terms, contract, disclaimer
  body      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduleTask {
  id             String         @id @default(cuid())
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name           String
  startDate      DateTime
  endDate        DateTime
  color          String         @default("#4c9a2a")
  progress       Int            @default(0)
  estimatedHours Float?
  assignee       String?
  parentId       String?
  parent         ScheduleTask?  @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  children       ScheduleTask[] @relation("SubTasks")
  order          Int            @default(0)
  status         String         @default("Not Started")
  type           String         @default("task") // "task" | "milestone"
  estimateItemId String?
  estimateItem   EstimateItem?  @relation(fields: [estimateItemId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Dependencies
  dependencies TaskDependency[] @relation("Dependent")
  dependents   TaskDependency[] @relation("Predecessor")

  // Time tracking
  timeEntries TimeEntry[]

  // Task details
  comments       TaskComment[]
  punchItems     TaskPunchItem[]
  assignments    TaskAssignment[]
  subAssignments SubTaskAssignment[]
}

model TaskDependency {
  id            String       @id @default(cuid())
  predecessorId String
  predecessor   ScheduleTask @relation("Predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  dependentId   String
  dependent     ScheduleTask @relation("Dependent", fields: [dependentId], references: [id], onDelete: Cascade)
  type          String       @default("FS") // FS = Finish-to-Start

  @@unique([predecessorId, dependentId])
}

model TaskComment {
  id                String       @id @default(cuid())
  taskId            String
  task              ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  subcontractorName String?      // display name for sub-portal comments
  text              String
  createdAt         DateTime     @default(now())
}

model TaskPunchItem {
  id        String       @id @default(cuid())
  taskId    String
  task      ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name      String
  completed Boolean      @default(false)
  assignee  String?
  photoUrl  String?
  order     Int          @default(0)
  createdAt DateTime     @default(now())
}

model TaskAssignment {
  id        String       @id @default(cuid())
  taskId    String
  task      ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String       @default("assigned") // assigned, lead
  createdAt DateTime     @default(now())

  @@unique([taskId, userId])
}

model Subcontractor {
  id            String  @id @default(cuid())
  companyName   String
  contactName   String?
  email         String  @unique
  phone         String?
  trade         String? // Electrical, Plumbing, HVAC, etc.
  licenseNumber String?
  status        String  @default("ACTIVE") // ACTIVE, INACTIVE

  // Expanded Details
  firstName     String?
  lastName      String?
  website       String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  zip           String?
  country       String?
  internalNotes String?

  // Certificate of Insurance
  coiFileUrl   String?
  coiExpiresAt DateTime?
  coiUploaded  Boolean   @default(false)

  // Relations
  taskAssignments SubTaskAssignment[]
  projectAccess   SubcontractorProjectAccess[]
  messageThreads  MessageThread[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubTaskAssignment {
  id              String        @id @default(cuid())
  subcontractorId String
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  taskId          String
  task            ScheduleTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([subcontractorId, taskId])
}

model FileFolder {
  id        String        @id @default(cuid())
  name      String
  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    FileFolder?   @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  FileFolder[]  @relation("FolderHierarchy")
  files     ProjectFile[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ProjectFile {
  id           String      @id @default(cuid())
  name         String
  url          String
  size         Int         @default(0)
  mimeType     String      @default("application/octet-stream")
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leadId       String?
  lead         Lead?       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  folderId     String?
  folder       FileFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?       @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime    @default(now())

  @@index([projectId])
  @@index([leadId])
  @@index([folderId])
}

model UserPermission {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Administrative
  manageTeamMembers   Boolean @default(false)
  manageSubs          Boolean @default(false)
  manageVendors       Boolean @default(false)
  companySettings     Boolean @default(false)
  costCodesCategories Boolean @default(true)

  // Project-level screen access
  schedules        Boolean @default(true)
  estimates        Boolean @default(false)
  invoices         Boolean @default(false)
  contracts        Boolean @default(false)
  roomDesigner     Boolean @default(true)
  changeOrders     Boolean @default(false)
  financialReports Boolean @default(false)
  timeClock        Boolean @default(true)
  dailyLogs        Boolean @default(true)
  files            Boolean @default(true)
  takeoffs         Boolean @default(false)

  // Leads
  createLead          Boolean @default(false)
  clientCommunication Boolean @default(false)
  leadAccess          Boolean @default(false)

  // Auto-grant new projects
  autoGrantNewProjects Boolean @default(true)
}

model ProjectAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

model Takeoff {
  id          String  @id @default(cuid())
  name        String
  description String?
  status      String  @default("Draft") // Draft, In Progress, Completed

  // Flexible Relation: Can belong to a Project OR a Lead
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // AI-generated estimate data (JSON string)
  aiEstimateData String?

  // Link to an actual Estimate if one was created from this takeoff
  estimateId String?   @unique
  estimate   Estimate? @relation(fields: [estimateId], references: [id])

  files TakeoffFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([leadId])
}

model TakeoffFile {
  id        String   @id @default(cuid())
  takeoffId String
  takeoff   Takeoff  @relation(fields: [takeoffId], references: [id], onDelete: Cascade)
  name      String
  url       String
  mimeType  String   @default("application/octet-stream")
  size      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([takeoffId])
}

model EstimateTemplate {
  id        String                 @id @default(cuid())
  name      String
  items     EstimateTemplateItem[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

model EstimateTemplateItem {
  id            String           @id @default(cuid())
  templateId    String
  template      EstimateTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  type          String           @default("Material")
  quantity      Float            @default(1)
  baseCost      Decimal?
  markupPercent Float            @default(25)
  unitCost      Decimal            @default(0)
  order         Int              @default(0)
  parentId      String?
  costCodeId    String?
  costTypeId    String?
}

model PortalVisibility {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  showSchedule     Boolean @default(true)
  showFiles        Boolean @default(true)
  showDailyLogs    Boolean @default(false)
  showEstimates    Boolean @default(true)
  showInvoices     Boolean @default(true)
  showContracts    Boolean @default(true)
  showMessages     Boolean @default(true)
  showChangeOrders Boolean @default(true)
  showSelections   Boolean @default(true)
  showMoodBoards   Boolean @default(true)

  isPortalEnabled      Boolean   @default(true)
  lastSharedAt         DateTime?
  lastShareEmailId     String?
  lastShareEmailStatus String? // "delivered", "opened", "clicked"
}

model MessageThread {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subcontractorId String?
  subcontractor   Subcontractor? @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  messages        Message[]
  createdAt       DateTime       @default(now())

  @@unique([projectId, subcontractorId])
}

model Message {
  id          String        @id @default(cuid())
  threadId    String
  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderType  String // "CLIENT", "TEAM", or "SUBCONTRACTOR"
  senderName  String
  senderEmail String?
  body        String
  readAt      DateTime?
  createdAt   DateTime      @default(now())
}

model ClientMessage {
  id           String    @id @default(cuid())
  // Belongs to either a Lead OR a Project (one must be set)
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  direction    String // "INBOUND" (from client) or "OUTBOUND" (from team)
  senderName   String
  senderEmail  String?
  subject      String?
  body         String
  channel      String    @default("email") // "email", "sms", "both", "app"
  attachments  String? // JSON array: [{ type, id, name, url }]
  sentViaEmail Boolean   @default(false)
  sentViaSms   Boolean   @default(false)
  status       String    @default("SENT") // SENT, SCHEDULED, FAILED
  scheduledFor DateTime?
  ccEmails     String? // JSON array of emails
  createdAt    DateTime  @default(now())
  readAt       DateTime? // Set when the recipient (team or client) reads the message

  // Twilio MessageSid for inbound idempotency + outbound observability.
  // Partial-unique index in DB: WHERE "twilioMessageSid" IS NOT NULL.
  twilioMessageSid String? @unique

  @@index([leadId])
  @@index([projectId])
  @@index([createdAt])
  @@index([readAt])
}

model SubcontractorProjectAccess {
  id              String        @id @default(cuid())
  subcontractorId String
  subcontractor   Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  viewedAt        DateTime?

  @@unique([subcontractorId, projectId])
}

model ChangeOrder {
  id          String   @id @default(cuid())
  number      Int      @default(autoincrement())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  code        String
  title       String
  description String?
  status      String   @default("Draft") // Draft, Sent, Approved, Declined
  totalAmount Decimal    @default(0)
  balanceDue  Decimal    @default(0)

  termsAndConditions String?
  memos              String?

  clientSignatureUrl  String?
  companySignatureUrl String?
  approvedBy          String?
  approvedAt          DateTime?
  sentAt              DateTime?
  viewedAt            DateTime?

  items            ChangeOrderItem[]
  paymentSchedules ChangeOrderPaymentSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChangeOrderItem {
  id            String      @id @default(cuid())
  changeOrderId String
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  type          String      @default("Material")
  quantity      Float       @default(1)
  baseCost      Decimal?
  markupPercent Float       @default(25)
  unitCost      Decimal       @default(0)
  total         Decimal       @default(0)
  order         Int         @default(0)
  costCodeId    String?
  costCode      CostCode?   @relation(fields: [costCodeId], references: [id])
  costTypeId    String?
  costType      CostType?   @relation(fields: [costTypeId], references: [id])
  createdAt     DateTime    @default(now())
}

model ChangeOrderPaymentSchedule {
  id            String      @id @default(cuid())
  changeOrderId String
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  name          String
  amount        Decimal
  dueDate       DateTime?
  order         Int         @default(0)
  createdAt     DateTime    @default(now())
}

model VendorTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  vendors   Vendor[]
  createdAt DateTime @default(now())
}

model VendorFile {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int?
  type      String?
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Vendor {
  id            String  @id @default(cuid())
  name          String
  website       String?
  description   String? @db.Text
  firstName     String?
  lastName      String?
  email         String?
  phone         String?
  fax           String?
  address1      String?
  address2      String?
  city          String?
  state         String?
  zipCode       String?
  country       String?
  paymentTerms  String?
  chargesTax    Boolean @default(false)
  accountNumber String?
  ein           String?
  notes         String? @db.Text
  status        String  @default("ACTIVE")

  tags           VendorTag[]
  files          VendorFile[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrder {
  id          String  @id @default(cuid())
  number      Int     @default(autoincrement())
  code        String
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId    String
  vendor      Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status      String  @default("Draft") // Draft, Sent, Received, Cancelled
  totalAmount Decimal   @default(0)
  notes       String?
  memos       String?
  terms       String?

  sentAt   DateTime?
  viewedAt DateTime?

  approvedBy String?
  approvedAt DateTime?

  items    PurchaseOrderItem[]
  files    PurchaseOrderFile[]
  expenses Expense[]
  messages PurchaseOrderMessage[]
  estimateItems EstimateItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrderMessage {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  gmailMessageId  String?       @unique
  body            String        @db.Text
  senderEmail     String
  senderName      String?
  senderType      String        @default("VENDOR") // TEAM, VENDOR, AI
  
  isAttachment    Boolean       @default(false)
  attachmentUrl   String?
  
  createdAt       DateTime      @default(now())
}

model PurchaseOrderFile {
  id              String        @id @default(cuid())
  name            String
  url             String
  size            Int
  type            String // Mime type
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  description String
  quantity    Float  @default(1)
  unitCost    Decimal  @default(0)
  total       Decimal  @default(0)
  order       Int    @default(0)

  costCodeId String?
  costCode   CostCode? @relation(fields: [costCodeId], references: [id])
  costTypeId String?
  costType   CostType? @relation(fields: [costTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SelectionBoard {
  id         String              @id @default(cuid())
  projectId  String
  project    Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  status     String              @default("Draft") // Draft, Sent, Selections Made
  categories SelectionCategory[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model SelectionCategory {
  id        String            @id @default(cuid())
  boardId   String
  board     SelectionBoard    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String
  order     Int               @default(0)
  options   SelectionOption[]
  createdAt DateTime          @default(now())
}

model SelectionOption {
  id          String            @id @default(cuid())
  categoryId  String
  category    SelectionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  imageUrl    String?
  price       Decimal?
  vendorUrl   String?
  selected    Boolean           @default(false)
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
}

model MoodBoard {
  id        String          @id @default(cuid())
  projectId String
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  items     MoodBoardItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model MoodBoardItem {
  id          String    @id @default(cuid())
  moodBoardId String
  moodBoard   MoodBoard @relation(fields: [moodBoardId], references: [id], onDelete: Cascade)
  type        String // "IMAGE", "TEXT", "SWATCH"
  content     String // Image URL, text body, or hex code
  x           Float     @default(0)
  y           Float     @default(0)
  width       Float     @default(200)
  height      Float     @default(200)
  zIndex      Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DailyLog {
  id                 String          @id @default(cuid())
  projectId          String
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById        String
  createdBy          User            @relation(fields: [createdById], references: [id])
  date               DateTime
  weather            String? // e.g. "Sunny, 75°F"
  crewOnSite         String? // comma-separated names or free text
  workPerformed      String          @db.Text
  materialsDelivered String?         @db.Text
  issues             String?         @db.Text
  photos             DailyLogPhoto[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model DailyLogPhoto {
  id         String   @id @default(cuid())
  dailyLogId String
  dailyLog   DailyLog @relation(fields: [dailyLogId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  createdAt  DateTime @default(now())
}

model Retainer {
  id          String   @id @default(cuid())
  code        String
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status      String   @default("Draft") // Draft, Sent, Partially Paid, Paid
  totalAmount Decimal    @default(0)
  balanceDue  Decimal    @default(0)
  amountPaid  Decimal    @default(0)
  notes       String?
  issueDate   DateTime?
  dueDate     DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  createdAt   DateTime @default(now())
}


model CatalogItem {
  id          String    @id @default(cuid())
  name        String
  description String?
  unitCost    Decimal     @default(0)
  unit        String    @default("each")
  costCodeId  String?
  costCode    CostCode? @relation(fields: [costCodeId], references: [id])
  isActive    Boolean   @default(true)
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BidPackage {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  status      String       @default("Draft") // Draft, Open, Awarded, Closed
  totalBudget Decimal?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  scopes      BidScope[]
  invitations BidInvitation[]
}

model BidScope {
  id           String     @id @default(cuid())
  packageId    String
  package      BidPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  budgetAmount Decimal?
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
}

model BidInvitation {
  id               String     @id @default(cuid())
  packageId        String
  package          BidPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  subcontractorId  String?
  email            String
  status           String     @default("Invited") // Invited, Viewed, Submitted, Declined, Awarded
  bidAmount        Decimal?
  notes            String?
  sentAt           DateTime?
  respondedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model DocumentComment {
  id             String   @id @default(cuid())
  documentType   String   // estimate, invoice, change-order, purchase-order, contract
  documentId     String
  visibility     String   @default("team") // team, client
  authorId       String?
  author         User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName     String?  // fallback for client/sub comments
  text           String
  createdAt      DateTime @default(now())

  @@index([documentType, documentId])
}

// ── Help Chat ────────────────────────────────────────────────────

model ChatConversation {
  id         String    @id @default(cuid())
  userId     String
  title      String?   // Auto-generated from first message
  archivedAt DateTime? // Auto-archived after 7 days of inactivity
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  messages   ChatMessage[]

  @@index([userId])
  @@index([userId, archivedAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" or "assistant"
  content        String
  createdAt      DateTime @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model TeamMessage {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String
  body       String
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorType  String   // "CLIENT", "TEAM", "SUBCONTRACTOR", "SYSTEM"
  actorName  String
  action     String   // "viewed_estimate", "signed_contract", "paid_invoice", "sent_message", "viewed_portal"
  entityType String?  // "estimate", "invoice", "contract", "change_order", "message"
  entityId   String?
  entityName String?  // e.g. "Estimate #E-001"
  metadata   String?  // JSON for extra data
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}
